{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "profiles-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/profiles/{**catch-all}" }
      },
      "calendar-route": {
        "ClusterId": "calendar-cluster",
        "Match": { "Path": "/api/calendar/{**catch-all}" }
      },
      "creators-route": {
        "ClusterId": "creator-cluster",
        "Match": { "Path": "/api/creators/{**catch-all}" }
      },
      "memberships-route": {
        "ClusterId": "creator-cluster",
        "Match": { "Path": "/api/memberships/{**catch-all}" }
      },
      "agency-route": {
        "ClusterId": "agency-cluster",
        "Match": { "Path": "/api/agencies/{**catch-all}" }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": { "Path": "/api/analytics/{**catch-all}" }
      },
      "marketplace-route": {
        "ClusterId": "marketplace-cluster",
        "Match": { "Path": "/api/marketplace/{**catch-all}" }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/hubs/{**catch-all}" }
      },
      "holodex-route": {
        "ClusterId": "holodex-cluster",
        "Match": { "Path": "/api/holodex/{**catch-all}" }
      },
      "twitch-route": {
        "ClusterId": "twitch-cluster",
        "Match": { "Path": "/api/twitch/{**catch-all}" }
      },
      "youtube-route": {
        "ClusterId": "youtube-cluster",
        "Match": { "Path": "/api/youtube/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7001" }
        }
      },
      "calendar-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7002" }
        }
      },
      "creator-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7003" }
        }
      },
      "community-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7004" }
        }
      },
      "agency-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7005" }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7006" }
        }
      },
      "marketplace-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7007" }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7008" }
        }
      },
      "holodex-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7009" }
        }
      },
      "twitch-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7010" }
        }
      },
      "youtube-cluster": {
        "Destinations": {
          "default": { "Address": "https://localhost:7011" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
